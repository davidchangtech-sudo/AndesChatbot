# Server
PORT=8000
# Set false only for local dev if crawl fails with CERTIFICATE_VERIFY_FAILED
HTTP_SSL_VERIFY=true
PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=https://www.andestech.com,https://andestech.com,http://localhost:8000,http://localhost:8080

# Google Gemini (get key from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# Supabase (Project Settings → API + Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional: direct Postgres URL for pgvector (Settings → Database → Connection string)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Crawl / RAG
CRAWL_BASE_URL=https://www.andestech.com/en/
SITEMAP_URLS=https://www.andestech.com/sitemap.xml,https://www.andestech.com/sitemap_index.xml,http://www.andestech.com/sitemap_index.xml
MAX_CRAWL_PAGES=2000
# Slow crawl avoids Wordfence rate limits (503 blocks)
# For a gentle full scan use: python scripts/slow_reindex.py
CRAWL_DELAY_SECONDS=2.5
CRAWL_CONCURRENCY=1
SITEMAP_CONCURRENCY=1
CRAWL_WORDFENCE_COOLDOWN=120
# Extra-gentle (slow_reindex.py defaults): DELAY=6, COOLDOWN=180
RAG_TOP_K=6
RAG_MIN_SIMILARITY=0.5

# Gemini fallback when KB has no/low-confidence match (see app/fallback_chat.py)
ENABLE_GEMINI_FALLBACK=true
RAG_FALLBACK_MAX_SIMILARITY=0.56

# Protect /reindex (cron or monthly script)
CRON_SECRET=generate_a_long_random_secret

# Sales dashboard at /admin (uses CRON_SECRET if unset)
LEAD_ADMIN_SECRET=

# Security (production: set PUBLIC_API_URL=https://your-api.com — enables origin checks, hides /test)
# REQUIRE_BROWSER_ORIGIN=true
# ENABLE_DEV_ROUTES=false
# TRUST_PROXY_HEADERS=true
# RATE_LIMIT_CHAT_PER_MINUTE=12
# RATE_LIMIT_CHAT_PER_HOUR=80
# RATE_LIMIT_LEADS_PER_HOUR=5
# RATE_LIMIT_GLOBAL_PER_MINUTE=120
# MAX_INFLIGHT_CHAT=25
# CHAT_TIMEOUT_SECONDS=45

# Lead notifications (optional, not wired yet)
LEAD_NOTIFY_EMAIL=
